# Core app settings
APP_ENV=development
FLASK_DEBUG=1
FLASK_SECRET_KEY=replace-with-a-long-random-secret
APP_ACCESS_PASSWORD=replace-with-a-strong-password

# Optional AI summary provider
ONE_MIN_AI_API_KEY=

# Optional LADBS browser overrides
LADBS_HEADLESS=1
LADBS_CHROME_BINARY=
LADBS_CHROMEDRIVER_PATH=
SE_CACHE_PATH=
LADBS_SELENIUM_PROFILE_DIR=
LADBS_DRIVER_START_RETRIES=2
LADBS_DRIVER_START_RETRY_DELAY_SECONDS=2
LADBS_PAGE_LOAD_TIMEOUT=45
LADBS_IMPLICIT_WAIT=1
